      "resolved": "packages/schema",
      "link": true
    },
    "node_modules/@boundaryml/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@boundaryml/storage": {
      "resolved": "packages/storage",
      "link": true
    },
    "node_modules/@boundaryml/studio": {
      "resolved": "apps/studio",
      "link": true
    },
    "packages/core": {
      "name": "@boundaryml/core",
      "version": "0.1.0"
    },
    "packages/generators": {
      "name": "@boundaryml/generators",
      "version": "0.1.0"
    },
    "packages/rules": {
      "name": "@boundaryml/rules",
      "version": "0.1.0"
    },
    "packages/schema": {
      "name": "@boundaryml/schema",
